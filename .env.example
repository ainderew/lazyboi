# ─────────────────────────────────────────────
# lazyboi · environment variables
# Copy to .env and fill in your own values.
# ─────────────────────────────────────────────

# ── runtime ──────────────────────────────────
# Set to "production" on a deployed server. Locally, leave unset or set to "development".
# In production the app expects PUPPETEER_EXECUTABLE_PATH to point at a real Chromium binary.
NODE_ENV=development

# Optional flag mirrored by some routes (kept for back-compat).
IS_PROD=false

# ── sprout (HR portal) credentials ───────────
# The password for your HR portal login (https://theoriamedical.hrhub.ph).
# Username is currently hardcoded in service/Attendance.service.js — edit it
# there if you fork this for yourself.
PASS=your-hr-portal-password

# ── puppeteer / chromium ─────────────────────
# Required in production. Path to the Chromium/Chrome binary on your server.
# Examples:
#   /usr/bin/chromium-browser   (Ubuntu/Debian — `apt install chromium-browser`)
#   /usr/bin/google-chrome-stable
# Leave unset locally — Puppeteer will use its bundled Chromium.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ── express session ──────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── slack fallback ───────────────────────────
# The Slack channel ID to post "in"/"out" messages into when the HR portal
# automation runs. Right-click the channel in Slack → "View channel details"
# → ID is at the bottom.
SLACK_CHANNEL_ID=C0XXXXXXXXX

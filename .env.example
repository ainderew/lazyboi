# ─────────────────────────────────────────────
# lazyboi · environment variables
# Copy to .env and fill in your own values.
# ─────────────────────────────────────────────

# ── runtime ──────────────────────────────────
# Set to "production" on a deployed server. Locally, leave unset or set
# to "development". In production the app expects PUPPETEER_EXECUTABLE_PATH
# to point at a real Chromium binary.
NODE_ENV=development

# Optional flag mirrored by some routes (back-compat).
IS_PROD=false

# ── target credentials ───────────────────────
# Password used by the primary Puppeteer flow.
# The username + target URL are configured in service/Attendance.service.js.
PASS=your-password

# ── puppeteer / chromium ─────────────────────
# Required in production. Path to the Chromium/Chrome binary on the server.
# Examples:
#   /usr/bin/chromium-browser   (Ubuntu/Debian — `apt install chromium-browser`)
#   /usr/bin/google-chrome-stable
# Leave unset locally — Puppeteer will use its bundled Chromium.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ── express session ──────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── slack relay ──────────────────────────────
# Slack channel ID the relay posts into.
# In Slack: right-click the channel → "View channel details" → ID is at the bottom.
SLACK_CHANNEL_ID=C0XXXXXXXXX
